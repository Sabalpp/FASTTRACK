# Local demos use the seeded localStorage role picker.
NEXT_PUBLIC_DEMO_MODE=true

# Supabase client-side values
NEXT_PUBLIC_SUPABASE_URL=
# Supabase now shows this as the publishable key in new projects.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy/fallback name supported by the app.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only. Never expose in browser code.
SUPABASE_SERVICE_ROLE_KEY=
# Protects the daily notification outbox catch-up endpoint on Vercel.
CRON_SECRET=

# Optional: used when real Google OAuth is enabled in Supabase.
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false
NEXT_PUBLIC_REQUIRE_OWNER_MFA=false

# Preferred: Google Places (New) browser key for address suggestions. Restrict
# the key to this app's production/preview domains and to Maps JavaScript API +
# Places API (New). Suggestions are biased toward Northern Virginia.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Optional fallback when Google Places is not configured.
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Optional Phase 2 CallRail webhook verification secret.
CALLRAIL_WEBHOOK_SECRET=

# Optional real email sending for invoices.
RESEND_API_KEY=
INVOICE_FROM_EMAIL=invoices@example.com

# Appointment confirmations (server-only). Email sends when a verified Resend
# sender is configured. SMS remains suppressed until each customer has recorded
# consent and Twilio credentials are configured.
APPOINTMENT_FROM_EMAIL=appointments@example.com
TWILIO_ACCOUNT_SID=
# Always required to verify webhook signatures, including when API-key
# credentials are used for outbound messages.
TWILIO_AUTH_TOKEN=
# Preferred outbound credentials for production.
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_MESSAGING_SERVICE_SID=
# Used only when a Messaging Service SID is not configured.
TWILIO_FROM_NUMBER=
# Exact HTTPS URL configured in Twilio for incoming messages. The app also
# supplies this URL as each outbound message's delivery status callback.
TWILIO_WEBHOOK_PUBLIC_URL=
