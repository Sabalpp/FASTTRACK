# Local demos use the seeded localStorage role picker.
NEXT_PUBLIC_DEMO_MODE=true

# Supabase client-side values
NEXT_PUBLIC_SUPABASE_URL=
# Supabase now shows this as the publishable key in new projects.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy/fallback name supported by the app.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only. Never expose in browser code.
SUPABASE_SERVICE_ROLE_KEY=
# One-time migration runner only. Paste the percent-encoded Supabase Postgres
# connection string; `npm run db:migrate` dry-runs before applying anything.
SUPABASE_DB_URL=
# Protects the daily notification outbox catch-up endpoint on Vercel.
CRON_SECRET=

# Optional: used when real Google OAuth is enabled in Supabase.
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false
NEXT_PUBLIC_REQUIRE_OWNER_MFA=false

# Enables Mapbox Geocoding v6 autocomplete automatically; no source toggle is
# required. Suggestions are limited to US addresses and biased toward Northern
# Virginia. Selected results use permanent geocoding because customer/job
# records persist them. Use a public token that can call Geocoding and Static
# Images/styles; permanent storage also requires Mapbox billing eligibility.
# Leave this and the fallback below blank for safe manual entry.
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
# Optional existing fallback when Mapbox is missing or temporarily unavailable.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional Phase 2 CallRail webhook verification secret.
CALLRAIL_WEBHOOK_SECRET=

# Transactional customer delivery (server-only). These providers are for
# invoices and appointment updates, never promotional campaigns. Customer
# transactional preferences/consent must not be reused as marketing consent.
#
# "auto" activates from credentials alone: SendGrid is preferred when
# SENDGRID_API_KEY is present, otherwise Resend is used. Set "sendgrid" or
# "resend" only when both keys exist and you need to force one provider.
TRANSACTIONAL_EMAIL_PROVIDER=auto
SENDGRID_API_KEY=
# global is the default. eu requires a SendGrid EU regional subuser/plan.
SENDGRID_REGION=global
RESEND_API_KEY=
# Shared verified sender fallback. Channel-specific values below override it.
TRANSACTIONAL_FROM_EMAIL=Fast Track <notifications@example.com>
INVOICE_FROM_EMAIL=Fast Track <invoices@example.com>
APPOINTMENT_FROM_EMAIL=Fast Track <appointments@example.com>

# Private invoice links sent by SMS expire after 7 days by default. Allowed
# range: 300 seconds through 2592000 seconds (30 days).
INVOICE_SMS_LINK_TTL_SECONDS=604800

# Twilio Programmable Messaging (server-only). SMS remains suppressed until
# the customer has current transactional SMS opt-in and all values are ready.
TWILIO_ACCOUNT_SID=
# Always required to verify webhook signatures, including when API-key
# credentials are used for outbound messages.
TWILIO_AUTH_TOKEN=
# Preferred outbound credentials for production; paste both or neither.
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_MESSAGING_SERVICE_SID=
# Used only when a Messaging Service SID is not configured.
TWILIO_FROM_NUMBER=
# Exact public HTTPS app URL for /api/webhooks/twilio. Register it in the
# Messaging Service for incoming messages/Advanced Opt-Out. Appointment sends
# also use it as their delivery status callback.
TWILIO_WEBHOOK_PUBLIC_URL=

# Stripe-hosted card checkout (server-only). Both secrets are required so the
# app can never charge a card without verified webhook reconciliation. Cash and
# check continue to work through the same invoice payment ledger.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Use test with sk_test_ credentials; switch both keys and this value to live
# only after production acceptance.
STRIPE_MODE=test
STRIPE_CURRENCY=usd
# Minimum 31 minutes leaves headroom over Stripe's 30-minute API minimum.
STRIPE_CHECKOUT_EXPIRY_MINUTES=31
# Canonical public app origin used for Checkout return URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000
