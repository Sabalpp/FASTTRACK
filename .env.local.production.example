# Required for real database mode
NEXT_PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=true
NEXT_PUBLIC_REQUIRE_OWNER_MFA=false
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Enables Mapbox Geocoding v6 autocomplete automatically; leave this and the
# fallback below blank for manual entry. Selected results use permanent
# geocoding because records persist them. Use one public token with Geocoding
# and Static Images/styles access; permanent storage requires Mapbox billing.
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
# Optional existing fallback when Mapbox is unavailable.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Server-only. Never expose to browser code.
SUPABASE_SERVICE_ROLE_KEY=
# Needed only by the local migration command, not by browser code.
SUPABASE_DB_URL=
# Long random value used by Vercel to authorize the daily outbox worker.
CRON_SECRET=

# Optional Phase 2
CALLRAIL_WEBHOOK_SECRET=

# Transactional email only. "auto" selects SendGrid when its key is present,
# then falls back to Resend; no source toggle is required.
TRANSACTIONAL_EMAIL_PROVIDER=auto
SENDGRID_API_KEY=
SENDGRID_REGION=global
RESEND_API_KEY=
TRANSACTIONAL_FROM_EMAIL=Fast Track <notifications@example.com>
INVOICE_FROM_EMAIL=Fast Track <invoices@example.com>
APPOINTMENT_FROM_EMAIL=Fast Track <appointments@example.com>
INVOICE_SMS_LINK_TTL_SECONDS=604800

# Twilio transactional SMS only. Existing customer SMS consent is not
# promotional consent. Register the public webhook in the Messaging Service.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM_NUMBER=
TWILIO_WEBHOOK_PUBLIC_URL=https://fasttrack-delta.vercel.app/api/webhooks/twilio

# Stripe-hosted card checkout. Register
# https://fasttrack-delta.vercel.app/api/webhooks/stripe and paste its whsec.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MODE=test
STRIPE_CURRENCY=usd
STRIPE_CHECKOUT_EXPIRY_MINUTES=31
NEXT_PUBLIC_APP_URL=https://fasttrack-delta.vercel.app
