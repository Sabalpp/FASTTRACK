# Required for real database mode
NEXT_PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=true
NEXT_PUBLIC_REQUIRE_OWNER_MFA=false
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Server-only. Never expose to browser code.
SUPABASE_SERVICE_ROLE_KEY=
# Long random value used by Vercel to authorize the daily outbox worker.
CRON_SECRET=

# Optional Phase 2
CALLRAIL_WEBHOOK_SECRET=

# Optional invoice email integration
RESEND_API_KEY=
INVOICE_FROM_EMAIL=invoices@example.com

# Appointment confirmations (server-only)
APPOINTMENT_FROM_EMAIL=appointments@example.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM_NUMBER=
TWILIO_WEBHOOK_PUBLIC_URL=https://fasttrack-delta.vercel.app/api/webhooks/twilio
