  "static_text_blocks": [
    {
      "id": "authorization_text",
      "text": "An estimate of $ __________ includes diagnosis/estimate, parts, and labor. I hereby authorize repairs and agree to pay for them upon completion of the job. If repairs require a part order, I agree to pay a deposit. I understand that the deposited amount will apply to the total for the trip to install parts. Company/technicians are not responsible for damages."
    },
    {
      "id": "additional_repairs_notice",
      "text": "If upon further analysis, additional repairs are found necessary, the customer will be contacted for the authorization of any additional charges. $35 Charge for return check."
    },
    {
      "id": "completion_text",
      "text": "I hearby acknowledge satisfactory performance of completion of repairs",
      "note": "Original appears to use the misspelling 'hearby'."
    },
    {
      "id": "hourly_rate_notice",
      "text": "WE DO NOT USE HOURLY RATE, where parts or service are required as they are often unfair and misleading to both the consumers and technicians; whose technical skills, experience, and knowledge can not be measured on hourly scale. We find; however, ALL CONSUMERS WANT THE MOST HIGHLY QUALIFIED TECHNICIAN AVAILABLE. Our goal is to provide you with those technicians and the related parts and backup service necessary."
    },
    {
      "id": "coupon",
      "text": "$50 OFF\nON YOUR NEXT\nCOMPLETE REPAIR"
    }
  ],
